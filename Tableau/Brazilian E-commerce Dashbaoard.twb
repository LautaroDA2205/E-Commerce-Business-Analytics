    <worksheet name='Revenue by Category'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1'>Top 10 Categories by Revenue</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='master_dataset' name='federated.0zwmp0g0zn7lko10n1miz0dufcv0' />
          </datasources>
          <datasource-dependencies datasource='federated.0zwmp0g0zn7lko10n1miz0dufcv0'>
            <column-instance column='[product_category_name_english]' derivation='None' name='[none:product_category_name_english:nk]' pivot='key' type='nominal' />
            <column datatype='real' name='[price]' role='measure' type='quantitative' />
            <column datatype='string' name='[product_category_name_english]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;auto&quot;' value='Auto' />
                <alias key='&quot;bed_bath_table&quot;' value='Bed, Bath &amp; Table' />
                <alias key='&quot;christmas_supplies&quot;' value='Christmas Supplies' />
                <alias key='&quot;computers_accessories&quot;' value='Computers Accessories' />
                <alias key='&quot;consoles_games&quot;' value='Consoles Games' />
                <alias key='&quot;cool_stuff&quot;' value='Cool Stuff' />
                <alias key='&quot;fashion_shoes&quot;' value='Fashion &amp; Shoes' />
                <alias key='&quot;furniture_decor&quot;' value='Furniture Decor' />
                <alias key='&quot;furniture_living_room&quot;' value='Furniture Living Room' />
                <alias key='&quot;furniture_mattress_and_upholstery&quot;' value='Furniture, Mattress &amp; Upholstery' />
                <alias key='&quot;garden_tools&quot;' value='Garden Tools' />
                <alias key='&quot;health_beauty&quot;' value='Health &amp; Beauty' />
                <alias key='&quot;home_appliances_2&quot;' value='Home Appliances' />
                <alias key='&quot;home_comfort_2&quot;' value='Home &amp; Comfort' />
                <alias key='&quot;housewares&quot;' value='Housewares' />
                <alias key='&quot;office_furniture&quot;' value='Office Furniture' />
                <alias key='&quot;security_and_services&quot;' value='Security &amp; Services' />
                <alias key='&quot;sports_leisure&quot;' value='Sports Leisure' />
                <alias key='&quot;watches_gifts&quot;' value='Watches Gifts' />
              </aliases>
            </column>
            <column-instance column='[price]' derivation='Sum' name='[sum:price:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0zwmp0g0zn7lko10n1miz0dufcv0].[none:product_category_name_english:nk]'>
